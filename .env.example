# ---- Public (safe to expose to the browser) ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ---- Server-only (NEVER prefix with NEXT_PUBLIC_) ----
# Service role key — bypasses RLS. Required for admin writes.
SUPABASE_SERVICE_KEY=eyJ...

# Single shared password gate for /admin/*.
# Pick something long. Rotate by changing this value.
ADMIN_PASSWORD=replace-me-with-a-strong-password

# >= 32 chars random string. Used to HMAC-sign admin + visitor cookies.
# Generate with: openssl rand -base64 48
SESSION_SECRET=replace-me-with-openssl-rand-base64-48
